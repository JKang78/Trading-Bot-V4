# Copy this file to .env and fill in your real keys:
#   cp .env.example .env

# === REQUIRED ===
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# === OPTIONAL ===
# CryptoCompare/CoinDesk — NOT required (free Fear & Greed is used instead)
CRYPTOCOMPARE_API_KEY=
# NewsData.io — optional extra news sentiment (free tier: newsdata.io)
NEWSDATA_API_KEY=your_newsdata_api_key_here
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Daily portfolio Telegram report ===
PORTFOLIO_REPORT_TIMEZONE=Asia/Seoul
PORTFOLIO_REPORT_SYMBOLS=BTC-USD,ETH-USD,XRP-USD,ADA-USD,SOL-USD,LINK-USD,DOGE-USD
PORTFOLIO_REPORT_SEND_TELEGRAM=true
# Keep false in CI so account details do not appear in workflow logs.
PORTFOLIO_REPORT_PRINT_STDOUT=false

# === SAFETY: keep true until you are ready for real trades ===
DRY_RUN=false

# === V4 features ===
# Sentiment works WITHOUT CryptoCompare (uses free Fear & Greed Index)
USE_SENTIMENT_ANALYSIS=true
USE_ONCHAIN_ANALYSIS=false
# Ensemble ON = require the 4-strategy vote to confirm entries (trades less).
USE_ENSEMBLE_SYSTEM=true
USE_RL_POSITION_SIZING=false

# Maker orders ON = post-only LIMIT entries (lower fee). Exits stay market.
USE_MAKER_ORDERS=true

# === Trading settings ===
MAX_POSITIONS=1
# Do NOT use 1 with margin: Kraken 1x = spot and cannot open SHORT positions.
LEVERAGE=2
STOP_LOSS_PCT=4.0
TAKE_PROFIT_PCT=8.0
TRAILING_STOP_PCT=2.5
V4_POSITION_STATE_FILE=v4_position_state.json

# === AI strategy router (strategy_router.py) ===
# Do not commit real keys. In GitHub, add OPENAI_API_KEY as an Actions secret.
OPENAI_API_KEY=
OPENAI_ROUTER_MODEL=gpt-5.5
OPENAI_ROUTER_REASONING_EFFORT=medium
ROUTER_DRY_RUN=false
ROUTER_AI_ENABLED=true
ROUTER_MAX_OPEN_POSITIONS=1
ROUTER_MAX_TRADE_MARGIN_FRACTION=0.25
ROUTER_MAX_TOTAL_MARGIN_FRACTION=0.35
ROUTER_MAX_LEVERAGE=2
ROUTER_ML_STRATEGIES=v2,v3

# === ML live trader (ml_live_trade.py) ===
# Strategy profile: v2 (default, more trades) or v3 (fewer, higher edge)
ML_LIVE_STRATEGY=v2
# ML_LIVE_STRATEGY=v3
ML_LIVE_DRY_RUN=false
ML_LIVE_MARGIN_SAFETY=1.0
