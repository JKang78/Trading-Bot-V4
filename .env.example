# Copy this file to .env and fill in your real keys:
#   cp .env.example .env

# === REQUIRED ===
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# === OPTIONAL ===
# CryptoCompare/CoinDesk — NOT required (free Fear & Greed is used instead)
CRYPTOCOMPARE_API_KEY=
# NewsData.io — optional extra news sentiment (free tier: newsdata.io)
NEWSDATA_API_KEY=your_newsdata_api_key_here
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Daily portfolio Telegram report ===
PORTFOLIO_REPORT_TIMEZONE=Asia/Seoul
PORTFOLIO_REPORT_SYMBOLS=BTC-USD,ETH-USD,XRP-USD,ADA-USD,SOL-USD,LINK-USD,DOGE-USD
PORTFOLIO_REPORT_SEND_TELEGRAM=true
# Keep false in CI so account details do not appear in workflow logs.
PORTFOLIO_REPORT_PRINT_STDOUT=false

# === SAFETY: keep true until you are ready for real trades ===
DRY_RUN=true

# === V4 features ===
# Sentiment works WITHOUT CryptoCompare (uses free Fear & Greed Index)
USE_SENTIMENT_ANALYSIS=true
USE_ONCHAIN_ANALYSIS=false
# Ensemble ON = require the 4-strategy vote to confirm entries (trades less).
USE_ENSEMBLE_SYSTEM=true
USE_RL_POSITION_SIZING=false

# Maker orders ON = post-only LIMIT entries (lower fee). Exits stay market.
USE_MAKER_ORDERS=true

# === Trading settings ===
MAX_POSITIONS=1
# Do NOT use 1 with margin: Kraken 1x = spot and cannot open SHORT positions.
LEVERAGE=2
STOP_LOSS_PCT=4.0
TAKE_PROFIT_PCT=8.0
TRAILING_STOP_PCT=2.5
V4_POSITION_STATE_FILE=v4_position_state.json

# Standalone old V4 bear-market gate. Use "all" to disable a symbol/direction list.
V4_ALLOWED_SYMBOLS=BTC-USD,ETH-USD
V4_ALLOWED_DIRECTIONS=short
V4_MIN_CONFIDENCE=0.80
V4_MAX_SIGNAL_AGE_HOURS=12
V4_TREND_EMA=200
V4_MIN_EXPECTANCY_PCT=0.25
V4_EXPECTED_HOLD_HOURS=12
V4_MAKER_ENTRY_FEE=0.0040
V4_TAKER_EXIT_FEE=0.0080
V4_MARGIN_OPEN_FEE=0.0004
V4_ROLLOVER_FEE_4H=0.0004
V4_SPREAD_SLIPPAGE_BUFFER=0.0015

# === AI strategy router (strategy_router.py) ===
# Do not commit real keys. In GitHub, add OPENAI_API_KEY as an Actions secret.
OPENAI_API_KEY=
OPENAI_ROUTER_MODEL=gpt-5.5
OPENAI_ROUTER_REASONING_EFFORT=medium
ROUTER_DECISION_LOG_FILE=router_decisions.jsonl
ROUTER_DRY_RUN=false
ROUTER_AI_ENABLED=true
ROUTER_MAX_OPEN_POSITIONS=1
ROUTER_MAX_TRADE_MARGIN_FRACTION=0.25
ROUTER_MAX_TOTAL_MARGIN_FRACTION=0.35
ROUTER_MAX_LEVERAGE=2
ROUTER_ML_STRATEGIES=v2,v3
ROUTER_ML_MAKER_ENTRY_FEE=0.0040
ROUTER_ML_TAKER_ENTRY_FEE=0.0080
ROUTER_ML_TAKER_EXIT_FEE=0.0080
ROUTER_ML_MARGIN_OPEN_FEE=0.0004
ROUTER_ML_ROLLOVER_FEE_4H=0.0004
ROUTER_ML_SPREAD_BUFFER=0.0005
ROUTER_ML_SLIPPAGE_BUFFER=0.0010

# V4 router hardening: only let V4 reach the AI router when it clears
# symbol/direction, trend, recency, confidence, and after-cost expectancy gates.
ROUTER_V4_SYMBOLS=BTC-USD,ETH-USD
ROUTER_V4_DIRECTIONS=short
ROUTER_V4_MIN_CONFIDENCE=0.80
ROUTER_V4_MAX_SIGNAL_AGE_HOURS=12
ROUTER_V4_TREND_EMA=200
ROUTER_V4_MIN_EXPECTANCY_PCT=0.25
ROUTER_V4_EXPECTED_HOLD_HOURS=12
ROUTER_V4_MAKER_ENTRY_FEE=0.0040
ROUTER_V4_TAKER_EXIT_FEE=0.0080
ROUTER_V4_MARGIN_OPEN_FEE=0.0004
ROUTER_V4_ROLLOVER_FEE_4H=0.0004
ROUTER_V4_SPREAD_SLIPPAGE_BUFFER=0.0015

# === ML live trader (ml_live_trade.py) ===
# Strategy profile: v2 (default, more trades) or v3 (fewer, higher edge)
ML_LIVE_STRATEGY=v2
# ML_LIVE_STRATEGY=v3
ML_LIVE_DRY_RUN=false
ML_LIVE_SYMBOLS=SOL-USD,LINK-USD,DOGE-USD
ML_LIVE_MAX_OPEN=3
ML_LIVE_POSITION_FRACTION=0.25
ML_LIVE_CONFIDENCE_SIZING=true
ML_LIVE_CONFIDENCE_LOW_PROB=0.72
ML_LIVE_CONFIDENCE_HIGH_PROB=0.78
ML_LIVE_CONFIDENCE_LOW_FRACTION=0.15
ML_LIVE_CONFIDENCE_MID_FRACTION=0.25
ML_LIVE_CONFIDENCE_HIGH_FRACTION=0.35
ML_LIVE_MARGIN_SAFETY=1.0
ML_LIVE_ALLOW_MIN_SIZE_BUMP=true
ML_LIVE_MAKER_ENTRY_FEE=0.0040
ML_LIVE_TAKER_ENTRY_FEE=0.0080
ML_LIVE_TAKER_EXIT_FEE=0.0080
ML_LIVE_MARGIN_OPEN_FEE=0.0004
ML_LIVE_ROLLOVER_FEE_4H=0.0004
ML_LIVE_SPREAD_BUFFER=0.0005
ML_LIVE_SLIPPAGE_BUFFER=0.0010
