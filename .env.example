# Copy this file to .env and fill in your real keys:
#   cp .env.example .env

# === REQUIRED ===
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# === OPTIONAL ===
# CryptoCompare/CoinDesk — NOT required (free Fear & Greed is used instead)
CRYPTOCOMPARE_API_KEY=
# NewsData.io — optional extra news sentiment (free tier: newsdata.io)
NEWSDATA_API_KEY=your_newsdata_api_key_here
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === SAFETY: keep true until you are ready for real trades ===
DRY_RUN=false

# === V4 features ===
# Sentiment works WITHOUT CryptoCompare (uses free Fear & Greed Index)
USE_SENTIMENT_ANALYSIS=true
USE_ONCHAIN_ANALYSIS=false
USE_ENSEMBLE_SYSTEM=false
USE_RL_POSITION_SIZING=false

# === Trading settings ===
MAX_POSITIONS=1
LEVERAGE=3
STOP_LOSS_PCT=4.0
TAKE_PROFIT_PCT=8.0
TRAILING_STOP_PCT=2.5
